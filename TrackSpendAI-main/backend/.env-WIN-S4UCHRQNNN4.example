# Backend environment variables
# Copy to `.env` and fill values before running

# Django secret
SECRET_KEY=your-very-secret-key

# Debug / hosts
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# MongoDB (Atlas or connection info)
MONGODB_USER=your_mongo_user
MONGODB_PASS=your_mongo_password
MONGODB_HOST=cluster0.example.mongodb.net
MONGODB_DATABASE_NAME=crownfinance_db

# Email (SMTP) if using Django send_mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Google / AI (only if you enable AI-related code)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# Add any other secrets needed for third-party services
# Example: STRIPE_SECRET_KEY=sk_live_...
